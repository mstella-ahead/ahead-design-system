{
  "$description": "AHEAD Design System tokens — machine-readable export. Keep in sync with tokens.css and tailwind.config.js.",
  "$version": "0.1.0",

  "color": {
    "brand": {
      "cyan":       { "value": "#009fdc", "comment": "Signature accent. Eyebrow text, link highlight on dark, primary CTA on dark." },
      "cyan-light": { "value": "#67c3e9", "comment": "Tinted cyan. Author bylines, second-quote color." },
      "blurple":    { "value": "#1c4cbf", "comment": "Default link color, primary CTA on light." },
      "navy":       { "value": "#123a61", "comment": "Deep brand navy." },
      "mid-navy":   { "value": "#253857", "comment": "Card backgrounds on dark." },
      "canvas":     { "value": "#102033", "comment": "Darkest section background. Use over pure black." },
      "near-black": { "value": "#181c24", "comment": "UI black." }
    },
    "surface": {
      "light": { "value": "#ebf0f2", "comment": "Light section background, default canvas for case studies, tag fill." },
      "white": { "value": "#ffffff" }
    },
    "text": {
      "default": { "value": "#181c24" },
      "muted":   { "value": "#6b7280" },
      "quiet":   { "value": "#5a5a5a" },
      "on-dark": { "value": "#ffffff" }
    },
    "border": {
      "quiet": { "value": "#c9c9c9" }
    },
    "accent": {
      "green": { "value": "#00b388" },
      "mint":  { "value": "#6eceb2" },
      "error": { "value": "#f87171" }
    }
  },

  "font": {
    "family": {
      "sans":  { "value": "Poppins, ui-sans-serif, system-ui, sans-serif" },
      "serif": { "value": "\"PT Serif\", Georgia, serif", "comment": "Italic emphasis only — never body text." },
      "mono":  { "value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace" }
    },
    "size": {
      "xs":   { "value": "1.2rem" },
      "sm":   { "value": "1.4rem" },
      "base": { "value": "1.5rem" },
      "md":   { "value": "1.7rem" },
      "lg":   { "value": "2rem" },
      "xl":   { "value": "2.5rem" },
      "2xl":  { "value": "3rem" },
      "3xl":  { "value": "3.6rem" },
      "4xl":  { "value": "5rem" }
    },
    "weight": {
      "thin":     { "value": "200" },
      "light":    { "value": "300", "comment": "Common default in the system." },
      "normal":   { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" }
    },
    "lineHeight": {
      "heading": { "value": "1.5", "comment": "All headings use this. Generous, deliberate." },
      "body":    { "value": "1.6" }
    },
    "tracking": {
      "eyebrow": { "value": "0.094em", "comment": "~1.5px at 1.2rem." }
    }
  },

  "radius": {
    "sharp":  { "value": "0",       "comment": "Image cards, hero blocks, section frames." },
    "sm":     { "value": "0.375rem" },
    "md":     { "value": "0.5rem" },
    "lg":     { "value": "0.8rem" },
    "pill":   { "value": "9999px",  "comment": "All buttons and tags." },
    "circle": { "value": "50%" }
  },

  "shadow": {
    "soft":   { "value": "0 0 20px rgba(0,0,0,0.15)" },
    "strong": { "value": "0 5px 15px rgba(0,0,0,0.25), 0 0 10px rgba(0,0,0,0.152)" },
    "lift":   { "value": "0 14px 28px rgba(0,0,0,0.25), 0 10px 10px rgba(0,0,0,0.22)" },
    "halo":   { "value": "0 0 15px rgba(0,0,0,0.7)" },
    "highlighter": {
      "cyan-rest":     { "value": "inset 0 -2px 0 0 #009fdc" },
      "cyan-hover":    { "value": "inset 0 -24px 0 0 #009fdc" },
      "blurple-rest":  { "value": "inset 0 -1px 0 0 #1c4cbf" },
      "blurple-hover": { "value": "inset 0 -24px 0 0 #1c4cbf" }
    }
  },

  "layout": {
    "container-max": { "value": "1440px" },
    "canvas-max":    { "value": "1920px" },
    "padding-mobile":  { "value": "2rem" },
    "padding-desktop": { "value": "5rem" },
    "section-gap":     { "value": "6rem" },
    "content-gap":     { "value": "2rem" }
  },

  "breakpoint": {
    "xs":  { "value": "375px" },
    "sm":  { "value": "420px" },
    "md":  { "value": "768px" },
    "lg":  { "value": "1024px" },
    "xl":  { "value": "1250px" },
    "2xl": { "value": "1340px", "comment": "Full layout breakpoint — side padding upgrades to 5rem here." },
    "3xl": { "value": "1920px" }
  },

  "motion": {
    "ease": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "duration": {
      "fast": { "value": "150ms" },
      "base": { "value": "200ms" }
    }
  }
}
